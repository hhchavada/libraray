        {
          "name": "Convert Demo to Permanent",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/v1/members/{{memberId}}/convert-to-permanent",
