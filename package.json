  "version": "1.0.0",
  "description": "Production-ready Node.js + Express + TypeScript + MongoDB boilerplate with MVC architecture",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/server.ts",
