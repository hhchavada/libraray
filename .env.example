PORT=5000
MONGO_URI=mongodb://localhost:27017/library-management
NODE_ENV=development
ACCESS_TOKEN_SECRET=your_access_token_secret_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
BCRYPT_SALT_ROUNDS=10
# Razorpay (Orders + Payment Links)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Optional — redirect after Payment Link success (default: APP_BASE_URL/api/v1/subscription/payment-callback)
# RAZORPAY_PAYMENT_CALLBACK_URL=

# Brevo Transactional Email API (recommended)
BREVO_API_KEY=your_brevo_api_key_here
# FROM address — must be verified in Brevo → Senders (NOT xxx@smtp-brevo.com)
BREVO_SENDER_EMAIL=harshchavada174@gmail.com
BREVO_SENDER_NAME=Library Management System

# Brevo SMTP (optional fallback)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
# SMTP login from Brevo → SMTP & API (usually xxx@smtp-brevo.com)
SMTP_USER=abb89a001@smtp-brevo.com
SMTP_PASS=your_brevo_smtp_password
# Same as BREVO_SENDER_EMAIL — what recipients see as "From"
SMTP_FROM=harshchavada174@gmail.com
OTP_EXPIRY_MINUTES=10

# App base URL (QR scan page opens here)
APP_BASE_URL=https://bridgrplatform.com
LIBRARY_QR_BASE_URL=https://bridgrplatform.com/scan
