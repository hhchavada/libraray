PORT=5000
MONGO_URI=mongodb://localhost:27017/library-management
NODE_ENV=development
ACCESS_TOKEN_SECRET=your_access_token_secret_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
BCRYPT_SALT_ROUNDS=10
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Brevo Transactional Email API (recommended)
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=your_verified_sender@example.com
BREVO_SENDER_NAME=Library Management System

# Brevo SMTP (optional fallback)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_smtp_login
SMTP_PASS=your_brevo_smtp_password
SMTP_FROM=your_verified_sender@example.com
OTP_EXPIRY_MINUTES=10

# App base URL (QR scan page opens here)
APP_BASE_URL=http://localhost:5000
LIBRARY_QR_BASE_URL=http://localhost:5000/scan
